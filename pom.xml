<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!--
        5COSC022W Client-Server Architectures Coursework (2025/26)
        SmartCampus Sensor & Room Management API
        Author : Rajapaksaha Thusew nambi Thenuja Hansana (20231300)
    -->

    <groupId>com.smartcampus</groupId>
    <artifactId>smartcampus-api</artifactId>
    <version>1.0</version>
    <packaging>jar</packaging>
    <name>SmartCampus Sensor and Room Management API</name>

    <properties>
        <maven.compiler.source>11</maven.compiler.source>
        <maven.compiler.target>11</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <!-- Jersey 2.x maintains the javax.ws.rs namespace required by the spec.
             Jersey 2.41 is the latest 2.x release.
             For JDK 17+ supply add-opens flags via the exec plugin and run script. -->
        <jersey.version>2.41</jersey.version>
        <mainClass>com.smartcampus.Main</mainClass>
    </properties>

    <dependencies>

        <!-- =========================================================
             Jersey 2.x + Grizzly embedded HTTP server
             Provides the javax.ws.rs.* namespace required by the spec
             ========================================================= -->
        <dependency>
            <groupId>org.glassfish.jersey.containers</groupId>
            <artifactId>jersey-container-grizzly2-http</artifactId>
            <version>${jersey.version}</version>
        </dependency>

        <!-- HK2 dependency-injection wiring required by Jersey -->
        <dependency>
            <groupId>org.glassfish.jersey.inject</groupId>
            <artifactId>jersey-hk2</artifactId>
            <version>${jersey.version}</version>
        </dependency>

        <!-- JSON (de)serialisation via Jackson -->
        <dependency>
            <groupId>org.glassfish.jersey.media</groupId>
            <artifactId>jersey-media-json-jackson</artifactId>
            <version>${jersey.version}</version>
        </dependency>

        <!-- Jackson core (pulled transitively but pinned for safety) -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <version>2.15.3</version>
        </dependency>

    </dependencies>

    <build>
        <plugins>

            <!-- Standard compiler -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.11.0</version>
                <configuration>
                    <source>11</source>
                    <target>11</target>
                </configuration>
            </plugin>

            <!-- Fat / uber-JAR so the server runs with: java -jar target/smartcampus-api-1.0-jar-with-dependencies.jar -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-assembly-plugin</artifactId>
                <version>3.6.0</version>
                <configuration>
                    <archive>
                        <manifest>
                            <mainClass>${mainClass}</mainClass>
                        </manifest>
                    </archive>
                    <descriptorRefs>
                        <descriptorRef>jar-with-dependencies</descriptorRef>
                    </descriptorRefs>
                </configuration>
                <executions>
                    <execution>
                        <id>assemble-all</id>
                        <phase>package</phase>
                        <goals>
                            <goal>single</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>

            <!-- Run directly without building a JAR: mvn exec:java
                 The jvmArguments below are required for Jersey 2.x on JDK 17+. -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <version>3.1.0</version>
                <configuration>
                    <mainClass>${mainClass}</mainClass>
                    <jvmArguments>
                        <jvmArgument>--add-opens=java.base/java.lang=ALL-UNNAMED</jvmArgument>
                        <jvmArgument>--add-opens=java.base/java.util=ALL-UNNAMED</jvmArgument>
                        <jvmArgument>--add-opens=java.base/java.io=ALL-UNNAMED</jvmArgument>
                        <jvmArgument>--add-opens=java.base/java.lang.reflect=ALL-UNNAMED</jvmArgument>
                        <jvmArgument>--add-opens=java.base/java.net=ALL-UNNAMED</jvmArgument>
                        <jvmArgument>--add-opens=jdk.unsupported/sun.misc=ALL-UNNAMED</jvmArgument>
                    </jvmArguments>
                </configuration>
            </plugin>

        </plugins>
    </build>
</project>
